# CrashPoint Integrations MCP — Environment Variables
# Copy this file to .env and fill in your values.

# Required: path to the ParentHolderFolder (shared with CrashPoint-IOS-MCP)
CRASH_ANALYSIS_PARENT=/path/to/ParentHolderFolder

# Optional: Zoho Cliq channel incoming webhook URL (the only Cliq integration method)
# Format: https://cliq.zoho.in/company/{org_id}/api/v2/channelsbyname/{channel_name}/message
ZOHO_CLIQ_WEBHOOK_URL=

# ── Zoho Projects MCP Integration ──────────────────────────────────────────
# Connect to the Zoho Projects MCP server for creating bugs from crash reports.
# The Zoho Projects MCP server handles its own authentication — no OAuth credentials needed here.
ZOHO_PROJECTS_MCP_URL=
ZOHO_PROJECTS_PORTAL_ID=
ZOHO_PROJECTS_PROJECT_ID=

# ── Zoho Bug Field Value IDs ───────────────────────────────────────────────
# Zoho Projects uses numeric field value IDs (not string labels) for status and severity.
# These IDs are unique per portal/project. Discover them via the Zoho Projects API or UI.
# If left blank, bugs will be created without that field set.

# Status IDs
ZOHO_BUG_STATUS_OPEN=
ZOHO_BUG_STATUS_FIXED=

# Severity IDs (all 5 levels)
ZOHO_BUG_SEVERITY_SHOWSTOPPER=
ZOHO_BUG_SEVERITY_CRITICAL=
ZOHO_BUG_SEVERITY_MAJOR=
ZOHO_BUG_SEVERITY_MINOR=
ZOHO_BUG_SEVERITY_NONE=

# ── Zoho Bug Custom Field Names ────────────────────────────────────────────
# The parameter names (keys) used when calling create_bug / update_bug on the
# Zoho Projects MCP.  These vary per portal layout, so set them to match the
# field names in YOUR Zoho Projects custom-field configuration.
# If left blank, the corresponding field won't be included in API calls.

# Custom field name for the app version (e.g. "single_line")
ZOHO_BUG_APP_VERSION=

# Custom field name for the occurrence count (e.g. "number_of_occurrences")
ZOHO_BUG_NUM_OF_OCCURRENCES=

# App version value to set on bugs (used together with ZOHO_BUG_APP_VERSION)
CRASH_VERSIONS=

# ── CrashPoint-IOS-MCP Variables ──────────────────────────────────────────────
# Required by CrashPoint-IOS-MCP (also referenced in .mcp.json for that server).
# Set these when using the automation pipeline.
DSYM_PATH=
APP_PATH=
APP_NAME=
CRASH_INPUT_DIR=
MASTER_BRANCH_PATH=
DEV_BRANCH_PATH=

# ── Automation Variables ───────────────────────────────────────────────────────
# Used by automation/run_crash_pipeline.sh to personalise the pipeline prompt
# and construct the --allowedTools flag for Claude CLI.

# Display name of the iOS app (used in the pipeline prompt, e.g. "Zoho Sprints")
APP_DISPLAY_NAME=

# Name of the Apptics MCP server exactly as shown in `claude mcp list`,
# with spaces replaced by underscores (e.g. M_APPTICS_ZMCP)
APPTICS_MCP_NAME=

# Name of the Zoho Projects MCP server exactly as shown in `claude mcp list`,
# with spaces replaced by underscores (e.g. M_PROJECTS_ZMCP)
PROJECTS_MCP_NAME=
