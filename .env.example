# CrashPoint Integrations MCP — Environment Variables
# Copy this file to .env and fill in your values.

# Required: path to the ParentHolderFolder (shared with CrashPoint-IOS-MCP)
CRASH_ANALYSIS_PARENT=/path/to/ParentHolderFolder

# Optional: Zoho Cliq channel incoming webhook URL (the only Cliq integration method)
# Format: https://cliq.zoho.in/company/{org_id}/api/v2/channelsbyname/{channel_name}/message
ZOHO_CLIQ_WEBHOOK_URL=

# ── Zoho Projects MCP Integration ──────────────────────────────────────────
# Connect to the Zoho Projects MCP server for creating bugs from crash reports.
# The Zoho Projects MCP server handles its own authentication — no OAuth credentials needed here.
ZOHO_PROJECTS_MCP_URL=
ZOHO_PROJECTS_PORTAL_ID=
ZOHO_PROJECTS_PROJECT_ID=

# ── Zoho Bug Field Value IDs ───────────────────────────────────────────────
# Zoho Projects uses numeric field value IDs (not string labels) for status and severity.
# These IDs are unique per portal/project. Discover them via the Zoho Projects API or UI.
# If left blank, bugs will be created without that field set.

# Status IDs
ZOHO_BUG_STATUS_OPEN=
ZOHO_BUG_STATUS_FIXED=

# Severity IDs (all 5 levels)
ZOHO_BUG_SEVERITY_SHOWSTOPPER=
ZOHO_BUG_SEVERITY_CRITICAL=
ZOHO_BUG_SEVERITY_MAJOR=
ZOHO_BUG_SEVERITY_MINOR=
ZOHO_BUG_SEVERITY_NONE=
